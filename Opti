import torch
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import os
from bayes_opt import BayesianOptimization

from Fv1_Surrogate import (
    Surrogate,
    build_road_signals,
    STATE_NAMES,
)

# ==============================
# Load Model
# ==============================
pkg = torch.load("Fv1_model_package.pth", map_location="cpu", weights_only=False)

cfg = pkg["cfg"]
scaler = pkg["scaler"]
state_dict = pkg["state_dict"]
device = cfg["device"]

model = Surrogate(cfg).to(device)
model.load_state_dict(state_dict)
model.eval()

print("Loaded model with Dx =", cfg["_Dx"])

# ==============================
# Build Road Data
# ==============================
def build_iso_dataframe_from_cfg(cfg):
    road = build_road_signals(cfg)

    return pd.DataFrame({
        "t": road["t"],
        "zr1L": road["zr1L"], "zr1R": road["zr1R"],
        "zr2L": road["zr2L"], "zr2R": road["zr2R"],
        "zr3L": road["zr3L"], "zr3R": road["zr3R"],
    })

df_iso = build_iso_dataframe_from_cfg(cfg)

# ==============================
# Build Input
# ==============================
def build_input_from_iso(df, Kf, Cf, K2, K3):
    WHEEL_COLS = ["zr1L","zr1R","zr2L","zr2R","zr3L","zr3R"]

    wheels = df[WHEEL_COLS].values.astype(np.float32)

    z1L,z1R,z2L,z2R,z3L,z3R = [df[c].values for c in WHEEL_COLS]

    z_r1 = 0.5*(z1L + z1R)
    z_r2 = 0.5*(z2L + z2R)
    z_r3 = 0.5*(z3L + z3R)

    phi1 = (z1L - z1R)/cfg["WT1"]
    phi2 = (z2L - z2R)/cfg["WT2"]
    phi3 = (z3L - z3R)/cfg["WT3"]

    phiNRS2 = (cfg["beta_L2"]*cfg["L_DL2"] - cfg["beta_R2"]*cfg["L_DR2"]) / max(cfg["S_tf2"],1e-6)
    phiNRS3 = (cfg["beta_L3"]*cfg["L_DL3"] - cfg["beta_R3"]*cfg["L_DR3"]) / max(cfg["S_tf3"],1e-6)

    derived = np.stack([
        z_r1, z_r2, z_r3,
        phi1, phi2, phi3,
        np.full_like(z_r1, phiNRS2),
        np.full_like(z_r1, phiNRS3)
    ], axis=-1).astype(np.float32)

    X = np.concatenate([wheels, derived], axis=1)
    t = df["t"].values.astype(np.float32)

    return torch.tensor(t).to(device), torch.tensor(X).to(device)

# ==============================
# SURROGATE (QDD BASED)
# ==============================
def run_surrogate(Kf, Cf, K2, K3):
    t, X = build_input_from_iso(df_iso, Kf, Cf, K2, K3)

    with torch.no_grad():
        Y = model(t, X)

    Y_np = Y.cpu().numpy()
    n_states = len(STATE_NAMES)

    QDD = Y_np[:, 2*n_states:3*n_states]

    idx_zc = STATE_NAMES.index("z_c")
    a = QDD[:, idx_zc]

    return float(np.sqrt(np.mean(a**2) + 1e-12))

# ==============================
# OBJECTIVE
# ==============================
def objective(Kf, Cf, K2, K3):
    return -run_surrogate(Kf, Cf, K2, K3)

# ==============================
# OPTIMIZATION
# ==============================
bounds = {
    "Kf": (0.8*cfg["K_f"], 1.2*cfg["K_f"]),
    "Cf": (0.8*cfg["C_f"], 1.2*cfg["C_f"]),
    "K2": (0.8*cfg["K_2"], 1.2*cfg["K_2"]),
    "K3": (0.8*cfg["K_3"], 1.2*cfg["K_3"]),
}

optimizer = BayesianOptimization(
    f=objective,
    pbounds=bounds,
    random_state=123,
)

print("Running Bayesian Optimization...")

optimizer.maximize(init_points=5, n_iter=30)

print("\nBest parameters found:")
print(optimizer.max)

# ==============================
# PLOTS
# ==============================
os.makedirs("results", exist_ok=True)

iterations = list(range(1, len(optimizer.res)+1))

# TRUE RMS values
true_targets = []
for res in optimizer.res:
    p = res["params"]
    true_targets.append(run_surrogate(p["Kf"], p["Cf"], p["K2"], p["K3"]))

# ------------------------------
# 1. Convergence
# ------------------------------
best_vals = []
best = float("inf")

for t in true_targets:
    best = min(best, t)
    best_vals.append(best)

plt.figure()
plt.plot(iterations, best_vals)
plt.xlabel("Iteration")
plt.ylabel("Cabin RMS")
plt.title("Convergence (True RMS)")
plt.grid()
plt.savefig("results/convergence.png")
plt.show()

# ------------------------------
# 2. Parameter Evolution
# ------------------------------
kf = [r["params"]["Kf"] for r in optimizer.res]
cf = [r["params"]["Cf"] for r in optimizer.res]
k2 = [r["params"]["K2"] for r in optimizer.res]
k3 = [r["params"]["K3"] for r in optimizer.res]

plt.figure()
plt.plot(kf, label="Kf")
plt.plot(cf, label="Cf")
plt.plot(k2, label="K2")
plt.plot(k3, label="K3")
plt.legend()
plt.title("Parameter Evolution")
plt.grid()
plt.savefig("results/param_evolution.png")
plt.show()

# ------------------------------
# 3. Scatter Plots
# ------------------------------
def scatter(x, y, name):
    plt.figure()
    plt.scatter(x, y)
    plt.xlabel(name)
    plt.ylabel("Cabin RMS")
    plt.title(f"{name} vs RMS")
    plt.grid()
    plt.savefig(f"results/{name}.png")
